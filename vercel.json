{
  "version": 2,
  "installCommand": "pnpm install --no-frozen-lockfile",
  "buildCommand": "pnpm --dir artifacts/api-server build",
  "functions": {
    "api/index.js": {
      "includeFiles": "{artifacts/api-server/dist/**,lib/db/dist/**}"
    }
  },
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/index.js"
    }
  ]
}
