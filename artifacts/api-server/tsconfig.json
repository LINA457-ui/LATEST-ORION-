{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "../..",
    "types": ["node"],

    "declaration": false,
    "declarationMap": false,
    "emitDeclarationOnly": false,

    "composite": false,
    "incremental": false,
    "noEmit": false,
    "noEmitOnError": false,

    "skipLibCheck": true
  },
  "include": [
    "src/**/*.ts",
    "../../lib/db/src/**/*.ts",
    "../../lib/api-zod/src/**/*.ts",
    "../../lib/integrations-openai-ai-server/src/**/*.ts"
  ],
  "exclude": ["dist", "node_modules"]
}