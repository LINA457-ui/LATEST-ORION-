{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "types": ["node"],
    "noImplicitAny": false,
    "declaration": false,
    "declarationMap": false,
    "emitDeclarationOnly": false,

    "composite": false,
    "incremental": false,
    "noEmit": false,
    "noEmitOnError": false,

    "skipLibCheck": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["dist", "node_modules"]
}